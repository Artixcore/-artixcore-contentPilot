# AI Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# App
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/contentpilot.db
DATABASE_TIMEOUT_SECONDS=30

DEFAULT_API_TIMEOUT_SECONDS=30
LONG_TASK_TIMEOUT_SECONDS=120

MAX_CONCURRENT_AI_REQUESTS=3
MAX_CONCURRENT_PUBLISH_REQUESTS=2
MAX_CONCURRENT_EXPORTS=2

AI_RATE_LIMIT_PER_MINUTE=20
CHAT_RATE_LIMIT_PER_MINUTE=30
PUBLISH_RATE_LIMIT_PER_MINUTE=10
EXPORT_RATE_LIMIT_PER_MINUTE=5
TELEGRAM_RATE_LIMIT_PER_MINUTE=30

CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_SECONDS=60

CACHE_PROVIDER_STATUS_TTL=60
CACHE_CONNECTOR_STATUS_TTL=60
CACHE_DASHBOARD_STATS_TTL=30
CACHE_SETTINGS_TTL=30

ENABLE_REAL_API_LOAD_TEST=false

# Telegram Controller
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8501/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_API_VERSION=202506

# X / Twitter
X_API_KEY=
X_API_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_REDIRECT_URI=http://localhost:8501/x/callback

# Meta / Facebook / Instagram
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8501/meta/callback
META_GRAPH_VERSION=v23.0
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_IG_USER_ID=

# Website / Artixcore CMS
WEBSITE_API_BASE_URL=
WEBSITE_API_TOKEN=
WEBSITE_POST_ENDPOINT=/api/posts
